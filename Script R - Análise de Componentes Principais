resultado_acp$rotation[,1:3]


# 3. Ver cargas do PC
#cargas_PC <- resultado_acp$rotation[,1] ; data.frame(cargas_PC)
cargas_PC <- resultado_acp$rotation[,1:3] ; data.frame(cargas_PC)
cargas_PC


# 4. Calcula a soma das cargas absolutas por variável
cargas_PC.df <- data.frame(abs(cargas_PC))
cargas_PC.df$Carga_Absoluta <- abs(cargas_PC.df$PC1) + abs(cargas_PC.df$PC2) + abs(cargas_PC.df$PC3)
