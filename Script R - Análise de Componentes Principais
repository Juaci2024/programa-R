# Executa a ACP
res_ACP1 <- PCA(banco_original1, ncp = 3, quanti.sup = c(6,11,14,15,16) , scale.unit = TRUE, graph = T)

# Extrai as contribuições das variáveis
contrib1 <- res_ACP1$var$contrib

# Define um limiar de contribuição (ex: 0.5% por componente principal)
# Aqui usamos 0.5 em vez de 50% porque a contribuição é dada em proporção
limiar <- 0.5  

# Filtra variáveis com contribuição > 0.5% para pelo menos um dos componentes
variaveis_relevantes <- rownames(contrib1)[apply(contrib1, 1, function(x) any(x > limiar))]

# Mostra as variáveis filtradas
contrib1[variaveis_relevantes, ]
