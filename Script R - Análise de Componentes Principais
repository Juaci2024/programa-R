#cargas_PC.df$Carga_Absoluta <- abs(cargas_PC.df$PC1)
cargas_PC.df


# 5. Pegar valores absolutos e normaliza os pesos
pesos <- abs(cargas_PC.df$Carga_Absoluta)


# 6. Calcula a soma total das cargas absolutas
soma_total <- sum(pesos)


# 7. Calcula o peso final de cada variável (normalizado para somar 1)
Pesos_Normalizados_wi <- pesos / soma_total


# 8. Adiciona o peso final na base de dados "cargas_PC.df"
